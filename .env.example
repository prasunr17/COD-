# Environment variables template
# Copy this to .env and fill in real values

# Server Configuration
NODE_ENV=development
PORT=3001

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cod_mvp
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cod_mvp

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production-min-32-chars-recommended

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Blockchain
TRON_PRIVATE_KEY=your_tron_private_key
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
TRON_RPC_URL=https://api.trongrid.io

# External APIs
COINGECKO_API_KEY=free
BINANCE_API_KEY=your_key
BINANCE_API_SECRET=your_secret

# Email (for future email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# AWS/Cloud
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=cod-mvp

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=

# Environment
ENVIRONMENT=development
NODE_ENV=development
